OPENROUTER_API_KEY=<OPENROUTER_API_KEY>

# Model selection: gpt-4o-mini is recommended (fast, low-cost, reliable)
# Get models list: https://openrouter.ai/docs#models
OPENROUTER_MODEL=openai/gpt-4o-mini

# Timeout for LLM requests (ms). 120000 = 2 minutes
LLM_TIMEOUT_MS=120000

# Optional: logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: LLM cache settings
LLM_CACHE_SIZE=1000
LLM_CACHE_TTL_SECONDS=3600

# Optional: retry settings for transient LLM failures
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_MS=100
